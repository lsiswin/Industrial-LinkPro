<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="768"
             xmlns:vm="clr-namespace:RadioIndustrialApp.ViewModels"
             x:DataType="vm:IndexViewModel"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             d:DataContext="{d:DesignInstance vm:IndexViewModel}"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             xmlns:models="clr-namespace:RadioIndustrialApp.Models"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:RadioIndustrialApp.Converters"
             x:Class="RadioIndustrialApp.Views.IndexView">
    <UserControl.Resources>
        <converters:StatusToBoolConverter x:Key="StatusToBoolConverter"/>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Button.tab-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#2D3142"/>
            <Setter Property="Foreground" Value="#8B8E99"/>
            <Setter Property="Padding" Value="12,5"/>
        </Style>
        <Style Selector="Button.tab-btn-active">
            <Setter Property="Background" Value="#1E2A4A"/>
            <Setter Property="BorderBrush" Value="#409EFF"/>
            <Setter Property="Foreground" Value="#409EFF"/>
            <Setter Property="Padding" Value="12,5"/>
        </Style>
        
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="150"></Setter>
            <Setter Property="Margin" Value="10,20,10,20"></Setter>
        </Style>
        <Style Selector="TextBlock.error">
            <Setter Property="Foreground" Value="#F44336"/>
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="Auto,*">
        <ItemsControl ItemsSource="{Binding DashboardCards}" Margin="20">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Columns="4" Rows="1"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:DashboardCardModel">
                <Border Margin="10" Padding="20" CornerRadius="12"
                        Background="#1A1C2E" BorderBrush="#2D3142" BorderThickness="1.5">
                    <Border.BoxShadow>
                        <BoxShadows>0 6 12 0 #50000000</BoxShadows>
                    </Border.BoxShadow>

                    <Grid RowDefinitions="Auto, *, Auto">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="{Binding Title}" Foreground="#8B8E99" FontSize="13" FontWeight="SemiBold"/>
                            <Border Grid.Column="1" Padding="8" CornerRadius="8" Background="#111322">
                                <PathIcon Data="{Binding IconData}" Foreground="{Binding AccentColor}"  Width="20" Height="20"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="{Binding Value}" 
                                       Foreground="{Binding AccentColor}" 
                                       FontSize="30" FontWeight="Heavy"/>
                        </StackPanel>

                        <ContentControl Grid.Row="2" Content="{Binding FooterContent}">
                            <ContentControl.DataTemplates>
                                
                                <DataTemplate DataType="models:OpcCommMetric">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{Binding Endpoint}" Foreground="#5C5E66" FontSize="11"/>
                                        <TextBlock Text="{Binding Latency}" Foreground="#4CAF50" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </DataTemplate>

                                <DataTemplate DataType="models:DataEngineLoad">
                                    <StackPanel Spacing="5">
                                        <ProgressBar Value="{Binding CpuUsage}" Height="3" CornerRadius="2"
                                                     Foreground="#2196F3" Background="#2D3142"/>
                                        <TextBlock Text="{Binding TotalNodes, StringFormat='点位总数: {0}'}" 
                                                   Foreground="#5C5E66" FontSize="10" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </DataTemplate>

                                <DataTemplate DataType="models:ActiveAlarm">
                                    <Border Background="#2A1A1F" Padding="8,5" CornerRadius="4">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <Border Width="3" Background="#F44336" CornerRadius="2" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Message}" 
                                                       Foreground="#DCDFE6" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>

                                <DataTemplate DataType="models:ProductionMetric">
                                    <Grid ColumnDefinitions="*, *">
                                        <TextBlock Text="{Binding Count, StringFormat='Total: {0}'}" Foreground="#8B8E99" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CycleTime, StringFormat='CT: {0}ms'}" 
                                                   Foreground="#00BCD4" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>

                            </ContentControl.DataTemplates>
                        </ContentControl>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
        <Grid Grid.Row="1" ColumnDefinitions="*, 450" Margin="20">
        
        <Border Grid.Column="0" Margin="0,0,15,0" Padding="25" Background="#16192C" CornerRadius="8" BorderBrush="#2D3142" BorderThickness="1">
            <Grid RowDefinitions="Auto, *">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel>
                        <TextBlock Text="系统数据采集负载趋势" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="采集引擎多线程性能实时监控" Foreground="#606266" FontSize="12" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Content="CPU负载" Classes="tab-btn-active"/>
                        <Button Content="内存占用" Classes="tab-btn"/>
                    </StackPanel>
                </Grid>
                
                <lvc:CartesianChart Grid.Row="1" Margin="0,30,0,0"
                                    Series="{Binding Series}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}" />
            </Grid>
        </Border>

        <Border Grid.Column="1" Padding="25"
                Background="#16192C" CornerRadius="8" BorderBrush="#2D3142" BorderThickness="1">
            <DockPanel>
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <TextBlock Text="PLC 设备快照" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="查看详情" Foreground="#409EFF" VerticalAlignment="Center" Cursor="Hand"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12" Padding="15" CornerRadius="6"
                                    Background="#1A1C2E" BorderBrush="#2D3142" BorderThickness="1">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Panel>
                                        <Border Width="45" Height="45" Background="#25283D" CornerRadius="4">
                                            <PathIcon Data="M2,2H22V22H2M4,4V20H20V4H4M6,6H18V10H6V6" Width="20" Foreground="#8B8E99"/>
                                        </Border>
                                        <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" 
                                                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-3,0"/>
                                    </Panel>

                                    <StackPanel Grid.Column="1" Margin="15,0">
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"
                                                   FontSize="14" Classes.error="{Binding Status, Converter={StaticResource StatusToBoolConverter}, ConverterParameter=ERROR}"/>
                                        <TextBlock Foreground="#606266" FontSize="11" Margin="0,4,0,0">
                                            <Run Text="IP: "/> <Run Text="{Binding IpAddress}"/>
                                            <Run Text=" | "/> <Run Text="{Binding Detail}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <Border Grid.Column="2" Padding="8,3" CornerRadius="4" Height="24"
                                            Background="#111322" BorderBrush="{Binding StatusColor}" BorderThickness="0.5">
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" 
                                                   FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>
    </Grid>
    </Grid>
</UserControl>
