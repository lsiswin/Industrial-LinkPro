<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             xmlns:vm="clr-namespace:RadioIndustrialApp.ViewModels"
             x:DataType="vm:AlarmsViewModel"
             x:Class="RadioIndustrialApp.Views.AlarmsView"
             Background="#030712">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *" Margin="24">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="24" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="活动报警:" Foreground="#94A3B8" FontSize="14"/>
                        <TextBlock Text="{Binding ActiveAlarmCount}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="紧急状态:" Foreground="#94A3B8" FontSize="14"/>
                        <TextBlock Text="{Binding CriticalCount}" Foreground="#EF4444" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            
            <Button Grid.Column="1" Content="全部确认" Command="{Binding AcknowledgeAllCommand}" Classes="primary" VerticalAlignment="Bottom"/>
        </Grid>

        <!-- Main Content -->
        <TabControl Grid.Row="1">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="FontSize" Value="16"/>
                    <Setter Property="Foreground" Value="#94A3B8"/>
                    <Setter Property="Padding" Value="20,10"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Foreground" Value="#38BDF8"/>
                </Style>
            </TabControl.Styles>
            
            <!-- Active Alarms Tab -->
            <TabItem Header="活动报警">
                <Border Classes="card" Margin="0,12,0,0">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding ActiveAlarms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E293B" CornerRadius="6" Padding="12" Margin="0,0,0,8" BorderBrush="{Binding SeverityColor}" BorderThickness="1,0,0,0">
                                        <Grid ColumnDefinitions="Auto, 100, 120, *, Auto">
                                            <TextBlock Text="{Binding SeverityIcon}" Foreground="{Binding SeverityColor}" FontSize="18" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Time}" Foreground="#94A3B8" VerticalAlignment="Center" FontFamily="Consolas"/>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Source}" Foreground="White" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding User}" Foreground="#64748B" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#E2E8F0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            
                                            <Button Grid.Column="4" Content="确认" 
                                                    Command="{Binding $parent[UserControl].((vm:AlarmsViewModel)DataContext).AcknowledgeAlarmCommand}" 
                                                    CommandParameter="{Binding}"
                                                    Background="#334155" Foreground="White" FontSize="12" Padding="8,4"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="历史记录">
                <Border Classes="card" Margin="0,12,0,0">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding AlarmHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F172A" CornerRadius="6" Padding="12" Margin="0,0,0,8" Opacity="0.7">
                                        <Grid ColumnDefinitions="Auto, 100, 120, *, Auto">
                                            <TextBlock Text="✓" Foreground="#10B981" FontSize="18" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Time}" Foreground="#64748B" VerticalAlignment="Center" FontFamily="Consolas"/>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Source}" Foreground="#94A3B8"/>
                                                <TextBlock Text="{Binding User}" Foreground="#475569" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#94A3B8" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Status}" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
