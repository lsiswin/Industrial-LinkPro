<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             xmlns:ia="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             xmlns:vm="clr-namespace:RadioIndustrialApp.ViewModels"
             x:DataType="vm:DeviceViewModel"
             x:Class="RadioIndustrialApp.Views.DeviceView"
             Background="#0B0F19">

    <!-- Trigger LoadDataCommand on view loaded -->
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <InvokeCommandAction Command="{Binding LoadDataCommand}" PassEventArgsToCommand="False" />
        </EventTriggerBehavior>
    </Interaction.Behaviors>

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Margin="20" Padding="20" CornerRadius="16"
                Background="#15FFFFFF" BorderBrush="#2FFFFFFF" BorderThickness="1">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Real-time device monitoring via OPC UA" FontSize="14" Foreground="#9CA3AF" Margin="0,5,0,0"/>
                </StackPanel>
                
                <Button Grid.Column="1" Command="{Binding LoadDataCommand}" CommandParameter="{x:True}" Classes="RefreshBtn" 
                        Background="#00D2FF" Foreground="Black" FontWeight="Bold" CornerRadius="8" Padding="15,10">
                    <TextBlock Text="REFRESH" />
                </Button>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True" 
                     IsVisible="{Binding IsLoading}" 
                     VerticalAlignment="Center" HorizontalAlignment="Center" 
                     Width="200" Height="4" Foreground="#00D2FF" />

        <!-- Main Content Split -->
        <Grid Grid.Row="1" ColumnDefinitions="320, *" Margin="20,0,20,20" IsVisible="{Binding !IsLoading}">
            
            <!-- Left: Device List -->
            <Border Grid.Column="0" CornerRadius="16" Background="#0AFFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" Padding="10">
                <!-- 隐藏 ListBox 默认选中背景 -->
                <ListBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" Background="Transparent" 
                         BorderThickness="0" CornerRadius="16" >
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#2000D2FF" />
                        </Style>
                    </ListBox.Styles>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Padding="15,10" Background="Transparent">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#9CA3AF" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="12" Padding="8,4" 
                                            Background="#2000E676" BorderBrush="#8000E676" BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" FontSize="10" Foreground="#00E676" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Right: Selected Device Data Points -->
            <Border Grid.Column="1" Margin="20,0,0,0" Padding="25" CornerRadius="16" Background="#0AFFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1">
                <Grid RowDefinitions="Auto, Auto, *">
                    
                    <!-- Selected Device Header -->
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedDevice.Name, TargetNullValue='尚未选择设备', FallbackValue='尚未选择设备'}" FontSize="24" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="{Binding SelectedDevice.Description}" FontSize="14" Foreground="#9CA3AF" Margin="0,5,0,0" />
                        </StackPanel>
                    </Grid>

                    <Separator Grid.Row="1" Background="#2FFFFFFF" Margin="0,15,0,20" />
                    
                    <!-- Data Points Container -->
                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding SelectedDevice.DataPoints}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" /> 
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,15,15" CornerRadius="8" Background="#0DFFFFFF" Padding="15" MaxWidth="220">

                                        <StackPanel>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock Text="{Binding Name}" FontSize="14" Foreground="#E5E7EB" FontWeight="Medium" />
                                            </Grid>
                                            <TextBlock Text="{Binding NodeId}" FontSize="11" Foreground="#6B7280" Margin="0,4,0,10" />
                                            
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <TextBlock Text="{Binding Value}" FontSize="28" FontWeight="Bold" Foreground="#00D2FF" />
                                                <TextBlock Text="{Binding Unit}" FontSize="14" Foreground="#9CA3AF" Margin="6,0,0,4" VerticalAlignment="Bottom" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
