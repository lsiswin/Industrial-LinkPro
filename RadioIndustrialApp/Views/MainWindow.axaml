<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RadioIndustrialApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="768"
        x:Class="RadioIndustrialApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        MinWidth="1200" MinHeight="700"
        Icon="/Assets/avalonia-logo.ico"
        Title="RadioIndustrialApp">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Window.Styles>
        <Style Selector="RadioButton.nav-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/> 
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"></Setter>
            <Setter Property="Padding" Value="0,0,0,5"/>
            <Setter Property="Margin" Value="15,0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            VerticalAlignment="Stretch"
                            BorderThickness="0,0,0,3"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal" 
                                    VerticalAlignment="Center" 
                                    HorizontalAlignment="Center"
                                    Margin="0,3,0,0">
                            <TextBlock Text="{TemplateBinding Tag}" 
                                       Margin="0,0,8,0" 
                                       VerticalAlignment="Center"/>
                            <ContentPresenter x:Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.nav-button:pointerover">
            <Setter Property="Foreground" Value="#60A5FA"/>
        </Style>
        <Style Selector="RadioButton.nav-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="#60A5FA"/>
        </Style>
        <Style Selector="RadioButton.nav-button:checked">
            <Setter Property="Foreground" Value="#3B82F6"/>
        </Style>
        <Style Selector="RadioButton.nav-button:checked /template/ Border#PART_RootBorder">
            <Setter Property="BorderBrush" Value="#3B82F6"/>
        </Style>
        <Style Selector="Ellipse.status-light">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style Selector="Ellipse.online">
            <Setter Property="Fill" Value="#22C55E"/>
            <Style.Animations>
                <Animation Duration="0:0:2" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1.0"/>
                        <Setter Property="ScaleTransform.ScaleX" Value="1.0"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0"/>
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.4"/>
                        <Setter Property="ScaleTransform.ScaleX" Value="1.1"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="1.1"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                        <Setter Property="ScaleTransform.ScaleX" Value="1.0"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Ellipse.error">
            <Setter Property="Fill" Value="#EF4444"/>
        </Style>
    </Window.Styles>
    
    <Grid RowDefinitions="Auto,*,Auto" Background="Azure">
        <Border BorderThickness="0,0,0,3" BorderBrush="#1E3AB1" Background="#1E293B" >
        <Grid ColumnDefinitions="Auto,*,Auto">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" >
                <TextBlock Text="♓" FontSize="40" Margin="10,10,0,0"/>
                <StackPanel Margin="10,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Industrial-Link Pro" FontWeight="Bold" FontSize="20" Margin="5,0,0,0" Foreground="White"/>
                        <TextBlock Text="v4.2.0" FontSize="12" VerticalAlignment="Bottom" Margin="5,0,0,0" Foreground="#94A3B8"/>
                    </StackPanel>
                    <TextBlock Text="工业数据采集与监控系统" Foreground="#60A5FA" Margin="5,5,0,0"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch" HorizontalAlignment="Center">
                <RadioButton Content="首页仪表盘" 
                             Tag="📊" 
                             Classes="nav-button" 
                             IsChecked="True"/>
                 
                <RadioButton Content="设备与标签" 
                             Tag="📦" 
                             Classes="nav-button"/>
                <RadioButton Content="数据分析" 
                             Tag="📈" 
                             Classes="nav-button"/>
                <RadioButton Classes="nav-button"
                             Tag="⚠️"
                             Content="报警记录"/>
                <RadioButton Content="系统设置" 
                             Tag="⚙️" 
                             Classes="nav-button"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <StackPanel Margin="10,0" VerticalAlignment="Center">
                    <TextBlock Text="2026年03月31日 14:30:22" Foreground="#94A3B8"></TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Ellipse Classes="status-light online" RenderTransformOrigin="50%,50%" />
                        <TextBlock Text="系统运行正常" Foreground="#4ADE80" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                <Rectangle Width="1" Height="24" Fill="#334155" Margin="4,0"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10" Margin="10.0,0,0,0">
                    <Border Width="32" Height="32" 
                            CornerRadius="16" 
                            Background="#1E293B" 
                            BorderBrush="White" 
                            BorderThickness="1">
                        <TextBlock Text="🙎‍♂️" 
                                   Foreground="#94A3B8" 
                                   FontSize="14"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
        
                    <TextBlock Text="Admin" 
                               Margin="0,0,10,0"
                               Foreground="#94A3B8" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</Window>
