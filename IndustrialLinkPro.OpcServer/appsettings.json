{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "DeviceApi": {
    "BaseUrl": "http://localhost:5288",
    "TimeoutSeconds": 15,
    "Auth": {
      "UserName": "admin",
      "Password": "Admin@123456"
    }
  },
  "SyncIntervalSeconds": 60,
  "DefaultScanIntervalMs": 1000,
  "OpcUa": {
    "ApplicationName": "IndustrialLinkPro OPC Server",
    "EndpointUrl": "opc.tcp://0.0.0.0:4842/IndustrialLinkPro",
    "BaseAddress": "urn:IndustrialLinkPro:OpcServer",
    "CertificateStore": "CertificateStores/MachineDefault",
    "NamespaceUri": "urn:industrial-linkpro:opcserver"
  },
  "Drivers": {
    "S7": {
      "ConnectTimeoutMs": 5000
    },
    "ModbusTcp": {
      "ConnectTimeoutMs": 5000
    }
  }
}
